# Workspace-specific credentials (loaded when this workspace is active).
# Copy to .env and fill in only what your sources.yaml needs.

# === Atlassian (Jira / Confluence) ===
# JIRA_EMAIL=
# JIRA_TOKEN=
# CONFLUENCE_TOKEN=

# === Code hosts ===
# GITHUB_TOKEN=
# GITLAB_TOKEN=

# === Linear ===
# LINEAR_API_KEY=

# === Google (single OAuth covers gmail / gdrive / gcal) ===
# GOOGLE_OAUTH_TOKEN=

# === Slack ===
# SLACK_TOKEN=

# === Notion ===
# NOTION_TOKEN=

# === Readwise ===
# READWISE_TOKEN=
