#!/usr/bin/env bash
# Block staged content that looks like a secret.
#
# Filename rules: any .env file is blocked unless it ends in .example,
# .sample, or .template. Common key files (*.pem, *.key, id_rsa*) blocked.
# Content rules: scans staged diff for known token shapes (GitHub, OpenAI,
# Anthropic, Slack, AWS, generic 'sk-' prefix).
#
# To bypass intentionally: git commit --no-verify

set -euo pipefail

mapfile -t STAGED < <(git diff --cached --name-only --diff-filter=ACM)
[[ ${#STAGED[@]} -eq 0 ]] && exit 0

BLOCKED_NAMES=(
    '^\.env$'
    '^\.env\..+$'
    '\.pem$'
    '\.key$'
    '\.p12$'
    '\.pfx$'
    '^id_rsa($|\.)'
    '^id_ed25519($|\.)'
    '^id_ecdsa($|\.)'
)
ALLOWED_NAME_SUFFIX_RE='\.(example|sample|template)$'

SECRET_PATTERNS=(
    'ghp_[A-Za-z0-9]{30,}'
    'gho_[A-Za-z0-9]{30,}'
    'ghu_[A-Za-z0-9]{30,}'
    'ghs_[A-Za-z0-9]{30,}'
    'github_pat_[A-Za-z0-9_]{50,}'
    'sk-ant-[A-Za-z0-9_-]{50,}'
    '\bsk-[A-Za-z0-9]{40,}'
    'xox[bpsr]-[A-Za-z0-9-]{20,}'
    'AKIA[0-9A-Z]{16}'
    '-----BEGIN ([A-Z]+ )?PRIVATE KEY-----'
)

violations=()

for f in "${STAGED[@]}"; do
    base=$(basename -- "$f")
    if [[ "$base" =~ $ALLOWED_NAME_SUFFIX_RE ]]; then
        continue
    fi
    for pat in "${BLOCKED_NAMES[@]}"; do
        if [[ "$base" =~ $pat ]]; then
            violations+=("$f  (blocked filename)")
            continue 2
        fi
    done

    # Skip binary diffs
    if git diff --cached --numstat -- "$f" | awk '{print $1$2}' | grep -q -- '-'; then
        continue
    fi

    added=$(git diff --cached -U0 -- "$f" | grep -E '^\+[^+]' || true)
    [[ -z "$added" ]] && continue
    for pat in "${SECRET_PATTERNS[@]}"; do
        if echo "$added" | grep -E -q "$pat"; then
            violations+=("$f  (content matches /$pat/)")
            break
        fi
    done
done

if [[ ${#violations[@]} -gt 0 ]]; then
    {
        echo "pre-commit BLOCKED — possible secret content:"
        printf '  - %s\n' "${violations[@]}"
        echo
        echo "If this is a false positive, override with: git commit --no-verify"
    } >&2
    exit 1
fi
